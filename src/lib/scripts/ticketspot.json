[
	{
    	"filter": [
        	{
                "field": "passTypeIdentifier",
                "match": "pass.com.ticketspot.*",
                "mimeType": "application/vnd.apple.pkpass",
                "scope": "Current"
        	}
        ],
        "function": "parsePass",
        "mimeType": "application/vnd.apple.pkpass",
        "script": "ticketspot.js"
    },
    {
        "filter": [
            {
                "match": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
                "mimeType": "text/plain",
                "scope": "Descendants"
            }
        ],
        "function": "parsePDF",
        "mimeType": "application/pdf",
        "script": "ticketspot.js"
    }
]